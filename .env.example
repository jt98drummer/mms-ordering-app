# Copy this file to ".env" and fill in. Or set these as environment variables on your host.

# Your Gelato API key (Gelato dashboard -> Settings -> API keys). Leave blank to stay in dry mode.
GELATO_API_KEY=

# dry | draft | live
#   dry   = build files + request, no Gelato call (safe, no key needed)
#   draft = create a DRAFT order in Gelato (not charged until you confirm in the dashboard)
#   live  = real order, charged to the card on your Gelato account, printed + shipped
GELATO_MODE=dry

# Public URL where Gelato can download the generated print files.
# Local testing: leave as localhost and use GELATO_MODE=dry.
# Deployed: set to your public app URL, e.g. https://mms-orders.onrender.com
PUBLIC_BASE_URL=http://localhost:8000

# Product codes — confirm the exact ones for your account by running:  python find_products.py
CARD_PRODUCT_UID=cards_pf_bx_pt_350-gsm-coated-silk_cl_4-4_hor
FLYER_PRODUCT_UID=flyers_pf_letter_pt_100-lb-text-coated-silk_cl_4-4_ver

SHIPMENT_METHOD=normal
CURRENCY=USD
NOTIFY_EMAIL=jtomlin@mmsinconline.com
