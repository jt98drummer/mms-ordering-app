# Copy this file to ".env" and fill in. Or set these as environment variables on your host (Render).

# ---- Gelato (print fulfillment for cards + documents) ----
GELATO_API_KEY=
GELATO_MODE=dry                      # dry | draft | live
PUBLIC_BASE_URL=http://localhost:8000
CARD_PRODUCT_UID=cards_pf_bx_pt_350-gsm-coated-silk_cl_4-4_hor
FLYER_PRODUCT_UID=cards_pf_lt_pt_250-gsm-coated-silk_cl_4-4_ver
SHIPMENT_METHOD=normal
CURRENCY=USD

# ---- Flask session secret (set a long random value in production) ----
FLASK_SECRET=

# ---- Microsoft 365 / Entra sign-in + Graph mail ----
# Sign-in turns ON automatically once all three of these are set.
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=                    # SECRET - host env only, never commit
MS_REDIRECT_PATH=/auth/callback
# Mailbox that receipts/approvals are sent FROM (needs app-only Mail.Send)
MAIL_SENDER=jtomlin@mmsinconline.com
MAIL_MODE=auto                       # auto = send when creds exist, else save to files/outbox

# ---- Order routing ----
ACCOUNTING_EMAIL=accounting@mmsinconline.com
ESCALATION_EMAIL=jtomlin@mmsinconline.com   # where a manager's own over-limit order escalates
NOTIFY_EMAIL=jtomlin@mmsinconline.com

# ---- Safety-net caps (adjust anytime) ----
DOC_MAX_QTY=25
FSE_MGR_AUTO_APPROVE_USD=250
EMPLOYEE_MAX_UNITS=5
EMPLOYEE_MAX_ORDER_USD=150

# ---- Dev only (when Entra creds are absent) ----
DEV_ROLE=employee                    # employee | fse | manager  (default preview role)

# ---- Durable audit (SharePoint mirror + mail archive) ----
ARCHIVE_EMAIL=                       # hidden BCC copy of every receipt, e.g. orders-archive@mmsinconline.com
SP_SITE_ID=                          # SharePoint site id (Graph) for the order-log list
SP_LIST_ID=                          # SharePoint list id or display name
# Create these list columns (single-line text unless noted):
#   Title(=order id), Store, Orderer, Email, Role, Payment, Qty (number), Amount, Purpose, ForWhom, Justification, Status, Approver

# ---- Stripe (personal-card swag; later phase) ----
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Printful (ALL apparel: print + embroidery) ----
PRINTFUL_API_KEY=
PRINTFUL_MODE=dry                    # dry | draft | live
# ---- Promo/other swag vendor (emailed PO) ----
VENDOR_EMAIL=                        # e.g. your promo rep who places tumbler/tech/bag/pen orders
